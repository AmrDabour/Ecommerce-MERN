{
  "title": "Docker Containers",
  "uid": "docker-containers",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Container CPU Usage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[2m]) * 100", "legendFormat": "{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 2, "type": "timeseries", "title": "Container RAM Usage",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "container_memory_usage_bytes{name!=\"\"}", "legendFormat": "{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 3, "type": "stat", "title": "Running Containers",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [{"expr": "count(container_last_seen{name!=\"\"})", "legendFormat": "Containers"}],
      "fieldConfig": {"defaults": {"mappings": []}}
    },
    {
      "id": 4, "type": "timeseries", "title": "Container Network Traffic",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 8},
      "targets": [
        {"expr": "rate(container_network_receive_bytes_total{name!=\"\"}[2m])", "legendFormat": "RX {{name}}"},
        {"expr": "rate(container_network_transmit_bytes_total{name!=\"\"}[2m])", "legendFormat": "TX {{name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    }
  ],
  "schemaVersion": 36
}
