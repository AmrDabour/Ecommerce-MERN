{
  "title": "Server Overview",
  "uid": "server-overview",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "CPU Usage",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU %"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "mappings": []}}
    },
    {
      "id": 2, "type": "stat", "title": "RAM Usage",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM %"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "mappings": []}}
    },
    {
      "id": 3, "type": "stat", "title": "Disk Usage",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100", "legendFormat": "Disk %"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}, "mappings": []}}
    },
    {
      "id": 4, "type": "stat", "title": "System Uptime",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "time() - node_boot_time_seconds", "legendFormat": "Uptime"}],
      "fieldConfig": {"defaults": {"unit": "s", "mappings": []}}
    },
    {
      "id": 5, "type": "timeseries", "title": "CPU Usage Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU %"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 6, "type": "timeseries", "title": "RAM Usage Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used"},
        {"expr": "node_memory_MemTotal_bytes", "legendFormat": "Total"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "Network Traffic",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[2m])", "legendFormat": "Receive {{device}}"},
        {"expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[2m])", "legendFormat": "Transmit {{device}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "id": 8, "type": "timeseries", "title": "Disk I/O",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "rate(node_disk_read_bytes_total[2m])", "legendFormat": "Read {{device}}"},
        {"expr": "rate(node_disk_written_bytes_total[2m])", "legendFormat": "Write {{device}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    }
  ],
  "schemaVersion": 36
}
