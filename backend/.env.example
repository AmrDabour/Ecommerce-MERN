# ==============================================================================
# ENVIRONMENT VARIABLES - BACKEND (TEMPLATE)
# Do not place actual secrets here, just the keys and sample values.
# ==============================================================================

# Server Configuration
PORT=5000

# Database Configuration (MongoDB)
DATA_BASE_URL=mongodb://localhost:27017/ecommerce

# Security & Authentication
SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_key_here

# Third-party Integrations
# Stripe Secret Key for payments
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Error Tracking (Sentry Node SDK)
SENTRY_DSN=your_sentry_dsn_here

# External Services
# URL of your frontend application
FRONTEND_URL=http://localhost:9837
# URL of the AI Python Microservice
AI_API_URL=http://localhost:8000/chat

# (Optional) Cloudinary credentials for images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
