# This is an example environment file.
# Do not place actual secrets here, just the keys and sample values.

# Server Port
PORT=3000

# MongoDB Connection String
DATA_BASE_URL=mongodb://localhost:27017/ecommerce

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_here

# (Optional) Cloudinary credentials for images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# (Optional) Stripe Secret Key for payments
STRIPE_SECRET=your_stripe_secret_key
