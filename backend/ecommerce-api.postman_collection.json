{
  "info": {
    "name": "E-Commerce API",
    "_postman_id": "ecommerce-api-collection",
    "description": "Full e-commerce backend API collection. After login, the token is saved automatically to the {{token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Mohamed\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01234567890\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"phone\": \"01000000000\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/login", "host": ["{{baseUrl}}"], "path": ["users", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/:id", "host": ["{{baseUrl}}"], "path": ["users", ":id"], "variable": [{ "key": "id", "value": "PASTE_USER_ID_HERE" }] }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/users/:id", "host": ["{{baseUrl}}"], "path": ["users", ":id"], "variable": [{ "key": "id", "value": "PASTE_USER_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"01111111111\",\n  \"address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Cairo\",\n    \"zip\": \"12345\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/:id", "host": ["{{baseUrl}}"], "path": ["users", ":id"], "variable": [{ "key": "id", "value": "PASTE_USER_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "PASTE_CATEGORY_ID_HERE" }] }
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic devices and accessories\"\n}"
            }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "PASTE_CATEGORY_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "PASTE_CATEGORY_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          }
        },
        {
          "name": "Get Products - Filter by Price",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?price[gte]=50&price[lte]=500",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "price[gte]", "value": "50" },
                { "key": "price[lte]", "value": "500" }
              ]
            }
          }
        },
        {
          "name": "Get Products - Sort and Paginate",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?sort=price&page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "sort", "value": "price" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/:id", "host": ["{{baseUrl}}"], "path": ["products", ":id"], "variable": [{ "key": "id", "value": "PASTE_PRODUCT_ID_HERE" }] }
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15 Pro\",\n  \"description\": \"Latest iPhone with A17 Pro chip\",\n  \"price\": 999,\n  \"priceAfterDiscount\": 899,\n  \"quantity\": 50,\n  \"category\": \"PASTE_CATEGORY_ID_HERE\",\n  \"imageCover\": \"https://example.com/iphone15.jpg\"\n}"
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/products/:id", "host": ["{{baseUrl}}"], "path": ["products", ":id"], "variable": [{ "key": "id", "value": "PASTE_PRODUCT_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 950,\n  \"quantity\": 45\n}"
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/products/:id", "host": ["{{baseUrl}}"], "path": ["products", ":id"], "variable": [{ "key": "id", "value": "PASTE_PRODUCT_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get All Reviews",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/reviews", "host": ["{{baseUrl}}"], "path": ["reviews"] }
          }
        },
        {
          "name": "Get Reviews By Product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reviews?product=PASTE_PRODUCT_ID_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["reviews"],
              "query": [{ "key": "product", "value": "PASTE_PRODUCT_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get Review By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/reviews/:id", "host": ["{{baseUrl}}"], "path": ["reviews", ":id"], "variable": [{ "key": "id", "value": "PASTE_REVIEW_ID_HERE" }] }
          }
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/reviews", "host": ["{{baseUrl}}"], "path": ["reviews"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": \"Great product!\",\n  \"rating\": 5,\n  \"product\": \"PASTE_PRODUCT_ID_HERE\"\n}"
            }
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/reviews/:id", "host": ["{{baseUrl}}"], "path": ["reviews", ":id"], "variable": [{ "key": "id", "value": "PASTE_REVIEW_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": \"Updated review\",\n  \"rating\": 4\n}"
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/reviews/:id", "host": ["{{baseUrl}}"], "path": ["reviews", ":id"], "variable": [{ "key": "id", "value": "PASTE_REVIEW_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/cart", "host": ["{{baseUrl}}"], "path": ["cart"] }
          }
        },
        {
          "name": "Add Product To Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/cart", "host": ["{{baseUrl}}"], "path": ["cart"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"PASTE_PRODUCT_ID_HERE\"\n}"
            }
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/cart/:itemId", "host": ["{{baseUrl}}"], "path": ["cart", ":itemId"], "variable": [{ "key": "itemId", "value": "PASTE_CART_ITEM_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          }
        },
        {
          "name": "Remove Item From Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/cart/:itemId", "host": ["{{baseUrl}}"], "path": ["cart", ":itemId"], "variable": [{ "key": "itemId", "value": "PASTE_CART_ITEM_ID_HERE" }] }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/cart/clear", "host": ["{{baseUrl}}"], "path": ["cart", "clear"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (from cart)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"cash\",\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Cairo\",\n    \"zip\": \"12345\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
          }
        },
        {
          "name": "Get Order By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/:id", "host": ["{{baseUrl}}"], "path": ["orders", ":id"], "variable": [{ "key": "id", "value": "PASTE_ORDER_ID_HERE" }] }
          }
        },
        {
          "name": "Mark Order As Paid (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/:id/pay", "host": ["{{baseUrl}}"], "path": ["orders", ":id", "pay"], "variable": [{ "key": "id", "value": "PASTE_ORDER_ID_HERE" }] }
          }
        },
        {
          "name": "Mark Order As Delivered (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/:id/deliver", "host": ["{{baseUrl}}"], "path": ["orders", ":id", "deliver"], "variable": [{ "key": "id", "value": "PASTE_ORDER_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "Coupons",
      "item": [
        {
          "name": "Get All Coupons (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/coupons", "host": ["{{baseUrl}}"], "path": ["coupons"] }
          }
        },
        {
          "name": "Create Coupon (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/coupons", "host": ["{{baseUrl}}"], "path": ["coupons"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SAVE20\",\n  \"discount\": 20,\n  \"expireDate\": \"2027-12-31\"\n}"
            }
          }
        },
        {
          "name": "Update Coupon (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/coupons/:id", "host": ["{{baseUrl}}"], "path": ["coupons", ":id"], "variable": [{ "key": "id", "value": "PASTE_COUPON_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discount\": 25\n}"
            }
          }
        },
        {
          "name": "Delete Coupon (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "token", "value": "{{token}}" }],
            "url": { "raw": "{{baseUrl}}/coupons/:id", "host": ["{{baseUrl}}"], "path": ["coupons", ":id"], "variable": [{ "key": "id", "value": "PASTE_COUPON_ID_HERE" }] }
          }
        },
        {
          "name": "Apply Coupon To Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/coupons/apply", "host": ["{{baseUrl}}"], "path": ["coupons", "apply"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SAVE20\"\n}"
            }
          }
        }
      ]
    }
  ]
}
